{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    /* Required for native Fetch API and Browser environment support */
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    
    /* Using 'Bundler' is the modern standard for Vite/Vue projects. 
       If using 'Node', use lowercase 'node' to avoid case-sensitivity issues in Linux/Docker.
    */
    "moduleResolution": "bundler",
    
    /* Silence deprecation warnings for 'baseUrl' and 'moduleResolution' 
       to ensure CI/CD pipeline completion.
    */
    "ignoreDeprecations": "5.0",
    
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "jsx": "preserve",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* --- LINTING & CODE QUALITY --- */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}