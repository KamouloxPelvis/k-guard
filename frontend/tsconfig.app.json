{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    /* Supported by modern environments for Fetch and Web APIs */
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    
    /* Modern standard for Vite projects, avoids most deprecation issues */
    "moduleResolution": "bundler",
    
    /* Revert to 5.0 to satisfy your local environment's validation */
    "ignoreDeprecations": "5.0",
    
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "jsx": "preserve",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["node"],
    
    /* We remove baseUrl and update paths to be absolute from root */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* --- CODE QUALITY & LINTING --- */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}