# ==========================================
# K-GUARD BACKEND CONFIGURATION EXAMPLE
# ==========================================

# --- NETWORKING & CORS ---
# Allow your frontend IP/Domain (e.g., port 30002 for NodePort)
ALLOWED_ORIGINS=http://localhost:30002,http://<YOUR_VPS_IP>:30002

# --- SECURITY & AUTHENTICATION ---
# NEVER put real passwords or hashes in this example file
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$EXAMPLE_HASH_REPLACE_ME
SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CISCO WEBEX INTEGRATION (Optional but recommended for DevNet) ---
# Your Webex Bot Token for security alerting
WEBEX_BOT_TOKEN=your_cisco_webex_bot_token_here
WEBEX_ROOM_ID=your_target_room_id_here

# --- INFRASTRUCTURE INFO ---
USER_DOMAIN=your-domain.com
PROJECT_NAME=K-Guard

# --- NETWORK SENTINEL CONFIGURATION ---
# Kubernetes namespaces to monitor by default
KGUARD_PROTECTED_NS=default,production,staging

# Path to the Ansible remediation playbook (Hardening)
KGUARD_ANSIBLE_PATH=./ansible/harden_network.yml

# --- SCANNER CONFIGURATION (TRIVY) ---
# Cache location to optimize SCA scanning resources
TRIVY_CACHE_DIR=/tmp/trivy-cache