# ==========================================
# K-GUARD BACKEND CONFIGURATION EXAMPLE
# ==========================================

# --- RÉSEAU & CORS ---
# Liste des origines autorisées (SANS slash final, séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:30002,http://113.30.191.17:30002,https://k-guard.votre-domaine.com

# --- SÉCURITÉ & AUTHENTIFICATION ---
ADMIN_USERNAME=kamal
ADMIN_PASSWORD_HASH=$2b$12$VOTRE_HASH_BCRYPT_ICI
SECRET_KEY=votre_cle_secrete_tres_longue_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# --- INFOS INFRASTRUCTURE ---
USER_DOMAIN=113.30.191.17
PROJECT_NAME=K-Guard

# --- CONFIGURATION NETWORK SENTINEL ---
# Namespaces à surveiller par défaut (séparés par des virgules) [cite: 2026-02-22]
KGUARD_PROTECTED_NS=k-guard,blog-prod,portfolio-prod

# Chemin relatif ou absolu vers le playbook Ansible de hardening [cite: 2026-02-22]
KGUARD_ANSIBLE_PATH=../infra/ansible/harden_network.yml

# --- CONFIGURATION SCANNER (TRIVY) ---
# Chemin vers le cache Trivy pour optimiser les ressources
TRIVY_CACHE_DIR=/data/trivy-cache