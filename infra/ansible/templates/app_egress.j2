# --- Specific Application Egress Policy ---
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Egress
  egress:
{% for rule in egress_rules %}
    - to:
      - ipBlock:
          cidr: {{ rule.cidr }}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port }}
{% endfor %}