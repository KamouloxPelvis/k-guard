# --- Specific Application Egress Policy ---
# Restricts outbound connections to prevent unauthorized data exfiltration
# and enforce Zero Trust connectivity between microservices.
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
  labels:
    managed-by: k-guard-sentinel
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Egress
  egress:
{% for rule in egress_rules %}
    - to:
{% if rule.to_app is defined %}
      # Service Discovery: Restrict communication to a specific target app
      - podSelector:
          matchLabels:
            app: {{ rule.to_app }}
{% else %}
      # Connectivity: Permit egress to a verified CIDR (Internal Cluster Subnet)
      - ipBlock:
          cidr: {{ rule.cidr }}
{% endif %}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port }}
{% endfor %}