# --- K-Guard Sentinel: Auditor Identity (RBAC) ---
# Creates a dedicated identity for diagnostic pods
apiVersion: v1
kind: ServiceAccount
metadata:
  name: sentinel-auditor
  namespace: {{ ns_item }}
  labels:
    managed-by: k-guard-sentinel
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: sentinel-auditor-role
  namespace: {{ ns_item }}
rules:
  - apiGroups: [""]
    resources: ["pods", "services", "endpoints"]
    verbs: ["get", "list"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: sentinel-auditor-binding
  namespace: {{ ns_item }}
subjects:
  - kind: ServiceAccount
    name: sentinel-auditor
    namespace: {{ ns_item }}
roleRef:
  kind: Role
  name: sentinel-auditor-role
  apiGroup: rbac.authorization.k8s.io
---
# --- K-Guard Sentinel: Network Exception ---
# Enables diagnostic pods to verify infrastructure health
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: sentinel-audit-exception
  namespace: {{ ns_item }}
  labels:
    managed-by: k-guard-sentinel
spec:
  podSelector:
    matchLabels:
      role: debug # This MUST match the --labels in your script
  policyTypes:
    - Egress
  egress:
    # 1. Authorize DNS Resolution
    - to:
        - namespaceSelector:{}
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
    # 2. Authorize K8s API access
    - to:
        - ipBlock:
            cidr: 0.0.0.0/0
      ports:
        - protocol: TCP
          port: 6443 # K3s
        - protocol: TCP
          port: 443  # HTTPS
    # 3. Authorize In-Cluster Service Reachability
    - to:
        - podSelector: {}