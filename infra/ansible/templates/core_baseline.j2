# --- Baseline: Zero Trust Isolation ---
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}-default-deny
  namespace: {{ namespace }}
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Ingress
    - Egress
---
# --- Infrastructure: DNS Access ---
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}-allow-dns
  namespace: {{ namespace }}
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Egress
  egress:
    - to:
      - namespaceSelector:
          matchLabels:
            kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53