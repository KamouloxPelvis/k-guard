# --- Baseline: Zero Trust Isolation ---
# This policy denies all ingress and egress traffic by default.
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: sentinel-default-deny
  namespace: {{ item }}
spec:
  podSelector: {} # Targets all pods in the namespace
  policyTypes:
    - Ingress
    - Egress
---
# --- Infrastructure: DNS Resolution ---
# Allows pods to talk to CoreDNS in kube-system.
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: sentinel-allow-dns
  namespace: {{ item }}
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
      - namespaceSelector:
          matchLabels:
            kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53