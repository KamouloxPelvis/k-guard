# --- Automated Ingress Policy for {{ app_label }} ---
# This policy is dynamically generated to control inbound traffic.
# It supports both external CIDR-based access and internal Pod-to-Pod communication.
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
  labels:
    managed-by: k-guard-sentinel
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Ingress
  ingress:
{% for rule in ingress_rules %}
    - from:
{% if rule.from_app is defined %}
      # Internal Microsegmentation: Allow traffic only from a specific application
      - podSelector:
          matchLabels:
            app: {{ rule.from_app }}
{% elif rule.cidr is defined %}
      # Perimeter Security: Allow traffic from specific IP ranges or external LoadBalancer
      - ipBlock:
          cidr: {{ rule.cidr }}
{% endif %}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port }}
{% endfor %}