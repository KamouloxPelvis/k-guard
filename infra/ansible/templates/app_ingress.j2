# --- Automated Ingress Policy for {{ app_label }} ---
# Dynamically regulates inbound traffic from external sources (CIDR)
# International standards: Compliant with Cisco DevNet
kind: NetworkPolicy
apiVersion: networking.k8s.io/v1
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
  labels:
    managed-by: k-guard-sentinel
spec:
  podSelector:
    matchLabels:
      app: {{ app_label }}
  policyTypes:
    - Ingress
  ingress:
{% for rule in ingress_rules %}
    - from:
{% if rule.from_app is defined %}
      # Internal Trust: Authorize specific peer pods
      - podSelector:
          matchLabels:
            app: {{ rule.from_app }}
{% elif rule.cidr is defined %}
      # Network Trust: Authorize specific IP blocks
      - ipBlock:
          cidr: {{ rule.cidr }}
{% endif %}
{% if rule.port is defined %}
      ports:
        - protocol: {{ rule.protocol | default('TCP') }}
          port: {{ rule.port }}
{% endif %}
{% endfor %}